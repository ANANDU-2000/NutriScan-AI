# Smart AI Food Scanner — copy to .env and fill values
# Local dev: DATABASE_URL can be omitted (uses SQLite)
# Production (Render): Set DATABASE_URL from Render PostgreSQL

OPENAI_API_KEY=sk-proj-your-key-here
SECRET_KEY=nutriscan_jwt_secret_2026_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local (default): sqlite. Production: postgresql from Render
# DATABASE_URL=sqlite:///./nutriscan.db
# DATABASE_URL=postgresql://user:pass@host/dbname

# Comma-separated origins (add your Vercel URL after deploy)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
DEBUG=False
